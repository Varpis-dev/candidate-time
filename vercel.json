{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/settings.php" },
    { "src": "/install", "dest": "/api/install.php" },
    { "src": "/settings", "dest": "/api/settings.php" },
    { "src": "/field", "dest": "/api/field.php" },
    { "src": "/options", "dest": "/api/options.php" },
    { "src": "/bind", "dest": "/api/bind.php" },

    { "src": "/contact.html", "dest": "/contact.html" },
    { "src": "/license.html", "dest": "/license.html" },
    { "src": "/privacy.html", "dest": "/privacy.html" }
  ]
}
